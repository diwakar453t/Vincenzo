# Production environment variables — Vercel reads these at build time.
# IMPORTANT: Override VITE_API_URL in the Vercel dashboard with your actual
# Railway backend URL (e.g. https://preskool-erp-production.up.railway.app/api/v1)
# This file is a safe default — it will NOT contain real secrets.

VITE_API_URL=https://your-railway-backend.up.railway.app/api/v1
